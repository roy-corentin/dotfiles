{
  "layer": "top", // Waybar at top layer
  "position": "top", // Waybar position (top|bottom|left|right)
  "output": "eDP-1",
  "font": "JetBrainsMono Nerd Font",
  "reload_style_on_change": true,
  "width": 1920, // Waybar width
  "spacing": 7, // Gaps between modules (4px)
  "modules-left": [
    "group/quicklinks-left",
    "wlr/taskbar",
    "network",
    "hyprland/window"
  ],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": [
    "mpd",
    "group/info",
    "group/hardware",
    "custom/keyboard",
    "clock",
    "group/quicklinks-right"
  ],

  // Modules configuration

  //Taskbar
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": "20",
    "on-click": "activate",
    "on-click-right": "close",
    "tooltip-format": "Go to {title}",
    "ignore-list": ["kitty", "kitty-scratchpad"]
  },

  "hyprland/workspaces": {
    "disable-scroll": true,
    "sort-by": "number",
    "all-outputs": true,
    "warp-on-scroll": false,
    "format": "{icon}",
    "format-icons": {
      "1": "¾░Ź¬",
      "2": "¾░¢¤",
      "3": "Ņ½ä",
      "4": "¾░ŗÄ",
      "default": "’äæ"
    }
    // "format-icons": {
    //   "urgent": "’ü¬",
    //   // "active": "’åÆ",
    //   "default": "’äæ"
    // },
  },
  // Quicklinks
  "group/quicklinks-left": {
    "orientation": "horizontal",
    "modules": ["image", "custom/settings", "custom/clipboard"]
  },
  "image": {
    "path": "/usr/share/endeavouros/EndeavourOS-icon.png",
    "on-click": "~/.config/rofi/appmenu.sh",
    "size": 18
  },
  "custom/settings": {
    "format": "’Ćō ",
    "tooltip": true,
    "tooltip-format": "Open Settings!",
    "on-click": "systemsettings"
  },

  "custom/vpn": {
    "format": "VPN ’ĆŻ",
    "exec": "echo '{\"class\": \"connected\"}'",
    "exec-if": "test -d /proc/sys/net/ipv4/conf/tun0",
    "return-type": "json",
    "interval": 5
  },

  "custom/clipboard": {
    "format": " ¾░©Ė ",
    "interval": "once",
    "tooltip": true,
    "tooltip-format": "Open Clipboard Manager!",
    "return-type": "json",
    "on-click": "~/.config/rofi/clipboardlist.sh",
    "on-click-middle": "rm -f ~/.cache/cliphist/db; waybar-signal clipboard",
    "exec": "printf '{\"tooltip\":\"%s\"}' $(cliphist list | wc -l)' item(s) in the clipboard\r(Mid click to clear)'",
    "exec-if": "[ -x \"$(command -v cliphist)\" ] && [ $(cliphist list | wc -l) -gt 0 ]",
    "signal": 9
  },

  "hyprland/window": {
    "icon": true,
    "icon-size": 18,
    "format": "¾░Ź¤ {title}",
    "rewrite": {
      "(.*) - Brave": "$1",
      ".*emacs -nw.*": "EmacsTTY",
      "(.*) - .*": "$1"
    },
    "separate-outputs": false,
    "max-length": 20
  },

  "group/quicklinks-right": {
    "orientation": "horizontal",
    "modules": [
      "idle_inhibitor",
      "custom/wallpaper",
      "custom/notification",
      "custom/power-menu"
    ]
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "’ü« ",
      "deactivated": "’ü░ "
    }
  },
  "custom/wallpaper": {
    "format": "’ĆŠ ",
    "on-click": "~/.config/rofi/wallpaper.sh",
    "tooltip": true,
    "tooltip-format": "’ĆŠ Change Wallpaper!"
  },
  "custom/power-menu": {
    "format": "’Ćæ ",
    "tooltip": true,
    "tooltip-format": "’Ćæ Open Wlogout!",
    "on-click": "wlogout"
  },

  "custom/pacman": {
    "format": "¾░”Ś {}",
    "interval": 3600, // every hour
    "exec": "checkupdates | wc -l", // check for updates
    "exec-if": "exit 0", // always run; consider advanced run conditions
    "on-click": "kitty --title float-system-update --hold --detach yay -Syyu",
    "signal": 8
  },

  "tray": {
    "icon-size": 21,
    "spacing": 10
  },

  "clock": {
    "format": "{:%e %b ¾░āŁ %H:%M ’ĆŚ} ",
    // "format-alt": "{:%Y-%m-%d}",
    "tooltip": true,
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "on-click": "kitty --title float-calcurse calcurse"
  },

  // Temperature
  "temperature": {
    "critical-threshold": 80,
    "format": "{temperatureC}┬░C {icon}",
    "hwmon-path-abs": "/sys/devices/pci0000:00/0000:00:01.0/0000:01:00.0/nvme/nvme0/hwmon1/temp1_input",
    "format-icons": ["’Ø½", "’ŗē", "’Ø®"]
  },

  // Network setup
  "network": {
    "format": "{ifname}",
    "format-wifi": "’ć½  {essid} {bandwidthDownBytes}",
    "format-ethernet": "ŅĮä  {bandwidthDownBytes}",
    "format-disconnected": "¾▒Źó No Internet",
    "tooltip-format": "¾░ŖŚ {ifname} via {gwaddr}",
    "tooltip-format-wifi": "’ć½  {ifname} {ipaddr} ({signalStrength}%)",
    "tooltip-format-ethernet": "ŅĮä  {ifname}",
    "max-length": 50,
    "interval": 2
  },

  // Quicklinks
  "group/info": {
    "orientation": "horizontal",
    "modules": ["battery", "pulseaudio"]
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 20
    },
    "format": "{icon} {capacity}%",
    // "format-charging": "¾▒Éŗ{capacity}%",
    "format-charging": "¾░éä {capacity}",
    "format-plugged": "’ć” {capacity}",
    // "format-alt": "{icon} {time}",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"],
    //"format-icons": ["¾▒āŹ", "¾░ü║", "¾░ü╝", "¾░üĮ", "¾░üŠ", "¾░ü┐", "¾░éĆ", "¾░éü", "¾░éé", "¾░ü╣"],
    "tooltip": true
  },

  "pulseaudio": {
    "scroll-step": 1, // %, can be a float
    "format": "{icon} {volume}%",
    "format-bluetooth": "{icon}’Ŗö {volume} {format_source}",
    "format-bluetooth-muted": "{icon}’Ŗö ’Ü® {format_source}",
    "format-muted": "¾░Ø¤ {format_source}",
    "format-source": "{volume}%",
    "format-source-muted": "’ä▒",
    "format-icons": {
      "headphone": "’Ćź",
      "hands-free": "’¢É",
      "headset": "’¢É",
      "default": ["’Ć”", "’Ć¦", "’Ć©"]
    },
    "max-volume": 150,
    "on-click": "pavucontrol"
  },
  // Hardware info
  "group/hardware": {
    "orientation": "horizontal",
    "modules": ["cpu", "memory"]
  },
  "cpu": {
    "format": "’ŗø {usage}% ",
    "interval": 5,
    "tooltip": false
  },
  "memory": {
    "format": "Ņē” {}%",
    "format-alt": "’æ▓ {used:0.1f}G",
    "interval": 5
  },

  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["¾░ā×", "¾░ā¤", "¾░āĀ"]
  },

  "custom/idle_inhibitor": {
    "interval": 60,
    "return-type": "json",
    "format": "{icon}",
    "format-icons": {
      "on": "¾░Æ│",
      "off": "¾░Æ▓"
    },
    "exec": "inhibit-idle",
    "on-click": "inhibit-idle off; inhibit-idle interactive",
    "on-click-middle": "inhibit-idle off",
    "signal": 15
  },

  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "ŅÄŹ",
      "ŅÅö",
      "ŅÅō",
      "ŅÅÆ",
      "ŅÅæ",
      "ŅÅÉ",
      "ŅÅÅ",
      "ŅÅÄ",
      "ŅÅŹ",
      "ŅÅī",
      "ŅÅŗ",
      "ŅÅŖ",
      "ŅÅē",
      "ŅÅł",
      "ŅÄø"
    ],
    "scroll-step": 1
  }
}
